# Vercel Project Environment Variables
# Add these in Vercel Dashboard > Project > Settings > Environment Variables.
# Do not commit real values. This file is only a checklist/template.

# Frontend browser-safe values
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
VITE_VAPID_PUBLIC_KEY=YOUR_PUBLIC_VAPID_KEY

# Backend server-only values
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_OR_SECRET_KEY
VAPID_PUBLIC_KEY=YOUR_PUBLIC_VAPID_KEY
VAPID_PRIVATE_KEY=YOUR_PRIVATE_VAPID_KEY

# Production app URL. Use the final deployed PWA origin.
ALLOWED_ORIGINS=https://yaraandb.vercel.app

# Optional, only needed for reminder/admin endpoints.
ADMIN_API_KEY=YOUR_LONG_RANDOM_ADMIN_API_KEY

# Admin panel login. Keep these server-only, never VITE_.
MASTER_ADMIN_USERNAME=master-admin
MASTER_ADMIN_PASSWORD=YOUR_LONG_PRIVATE_MASTER_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=YOUR_LONG_RANDOM_ADMIN_SESSION_SECRET

# Optional. Leave unset for same-origin Vercel deployment.
# If set, use the deployed site origin, not a localhost URL.
# VITE_API_BASE_URL=https://yaraandb.vercel.app
