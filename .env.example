# Frontend/local Vite environment
# Copy this file to `.env` for local frontend testing.
# Values with VITE_ are bundled into the browser, so only put public-safe values here.

# Supabase project URL. Same project as backend SUPABASE_URL.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/publishable key only. Never put the service role key here.
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Local backend API URL. For Vercel production this can usually be omitted
# because the frontend calls same-origin /api/... routes.
VITE_API_BASE_URL=http://localhost:3001

# Public VAPID key for browser push subscriptions.
VITE_VAPID_PUBLIC_KEY=YOUR_PUBLIC_VAPID_KEY
