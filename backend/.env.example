# Backend/local Node environment
# Copy this file to `backend/.env` for local backend testing.
# Never commit real backend secrets.

# Supabase project URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Backend-only Supabase service role/secret key.
# Required for app_users signup/login because app_users uses RLS.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_OR_SECRET_KEY

# Optional fallback public key for older local setups.
# Not enough for app_users signup/login by itself.
SUPABASE_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Optional local port. Defaults to 3001 if omitted.
PORT=3001

# Optional CORS allow-list. For local testing, include the Vite dev server.
ALLOWED_ORIGINS=http://localhost:5173

# Optional admin key for reminder/admin endpoints.
# Normal volunteer signup/login/recording does not need this.
ADMIN_API_KEY=YOUR_LONG_RANDOM_ADMIN_API_KEY

# Admin panel login. Master admin is environment-backed and cannot be edited
# or deleted by database admins.
MASTER_ADMIN_USERNAME=master-admin
MASTER_ADMIN_PASSWORD=YOUR_LONG_PRIVATE_MASTER_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=YOUR_LONG_RANDOM_ADMIN_SESSION_SECRET

# Push notification keys for backend reminder sending.
# Use non-VITE name for private key so it is never exposed to the browser.
VAPID_PUBLIC_KEY=YOUR_PUBLIC_VAPID_KEY
VAPID_PRIVATE_KEY=YOUR_PRIVATE_VAPID_KEY
